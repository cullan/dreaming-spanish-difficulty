{
  "manifest_version": 2,
  "name": "Dreaming Spanish Difficulty Ratings",
  "version": "1.0.0",
  "description": "Display difficulty ratings in the user interface.",
  "icons": {
    "48": "icons/fuerte.svg",
    "96": "icons/fuerte.svg"
  },
  "homepage_url": "https://github.com/cullan/dreaming-spanish-difficulty",
  "permissions": [
    "webRequest", "webRequestBlocking", "https://app.dreaming.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "57.0a1"
    }
  }
}
